# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Load into a shell with:  set -a; . ./.env; set +a

OPENROUTER_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=

# Optional: comma-separate multiple keys per provider via FREELM_<PROVIDER>_KEYS
# FREELM_OPENROUTER_KEYS=key1,key2

# Optional tiers
# FREELM_OPENROUTER_TIER=free      # free | credit
# FREELM_GOOGLE_TIER=free          # free | tier1

# Optional: persist quota/cooldown/disabled-key state across restarts
# (~/.cache/freelm/state.json — key hashes only, never raw keys)
# FREELM_PERSIST=1

# Maintainers only — PyPI upload token (never commit)
# PYPI_TOKEN=
